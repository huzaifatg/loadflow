generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TruckStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE

  @@map("truck_status")
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY

  @@map("driver_status")
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  CANCELLED

  @@map("delivery_status")
}

enum LoadPlanStatus {
  DRAFT
  READY
  DISPATCHED
  COMPLETED

  @@map("load_plan_status")
}

enum UnitType {
  STANDARD_WEIGHT
  VARIABLE_WEIGHT
  PIECE_BASED

  @@map("unit_type")
}

enum DeliverySource {
  MANUAL
  CSV
  EXCEL
  API
  WEBHOOK
  SHOPIFY
  WOOCOMMERCE
  ERP

  @@map("delivery_source")
}

enum ImportStatus {
  QUEUED
  UPLOADING
  PARSING
  MAPPING
  VALIDATING
  READY_FOR_REVIEW
  IMPORTING
  COMPLETED
  FAILED
  CANCELLED
  ROLLED_BACK

  @@map("import_status")
}

enum ImportRowStatus {
  PENDING
  VALID
  WARNING
  ERROR
  DUPLICATE
  SKIPPED
  IMPORTED

  @@map("import_row_status")
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @map("name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trucks     Truck[]
  drivers    Driver[]
  deliveries Delivery[]
  loadPlans  LoadPlan[]
  importJobs ImportJob[]

  // Settings
  timezone           String   @default("America/Chicago") @map("timezone")
  units              String   @default("imperial") @map("units")
  emailNotifications Boolean  @default(true) @map("email_notifications")
  dispatchAlerts     Boolean  @default(true) @map("dispatch_alerts")
  weeklyReport       Boolean  @default(false) @map("weekly_report")

  // Profile
  fullName           String   @default("Admin User") @map("full_name")
  displayName        String   @default("Admin") @map("display_name")
  phone              String   @default("") @map("phone")

  members            CompanyMember[]

  @@map("companies")
}

enum Role {
  OWNER
  ADMIN
  MEMBER

  @@map("role")
}

model CompanyMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      Role     @default(MEMBER) @map("role")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@map("company_members")
}


model Truck {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String      @map("company_id") @db.Uuid
  name           String      @map("name")
  type           String      @default("Box Truck") @map("type")
  plateNumber    String      @map("plate_number")
  weightCapacity Float       @map("weight_capacity")
  status         TruckStatus @default(AVAILABLE) @map("status")
  notes          String?     @map("notes")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  isArchived     Boolean     @default(false) @map("is_archived")
  archivedAt     DateTime?   @map("archived_at")

  company   Company    @relation(fields: [companyId], references: [id])
  loadPlans LoadPlan[] @relation("TruckLoadPlans")

  @@index([companyId, isArchived])
  @@map("trucks")
}

model Driver {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String       @map("company_id") @db.Uuid
  name          String       @map("name")
  phone         String?      @map("phone")
  licenseNumber String?      @map("license_number")
  status        DriverStatus @default(AVAILABLE) @map("status")
  notes         String?      @map("notes")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  isArchived    Boolean      @default(false) @map("is_archived")
  archivedAt    DateTime?    @map("archived_at")

  company   Company    @relation(fields: [companyId], references: [id])
  loadPlans LoadPlan[] @relation("DriverLoadPlans")

  @@index([companyId, isArchived])
  @@map("drivers")
}

model Delivery {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String         @map("company_id") @db.Uuid
  customerName    String         @map("customer_name")
  pickupAddress   String         @map("pickup_address")
  deliveryAddress String         @map("delivery_address")
  weight          Decimal        @default(0) @map("weight") @db.Decimal(12, 4)
  status          DeliveryStatus @default(PENDING) @map("status")
  scheduledDate   DateTime?      @map("scheduled_date")
  notes           String?        @map("notes")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  isArchived      Boolean        @default(false) @map("is_archived")
  archivedAt      DateTime?      @map("archived_at")

  // ─── Data Ingestion Fields ──────────────────────────────────────────────────
  externalId      String?        @map("external_id")
  source          DeliverySource @default(MANUAL) @map("source")
  sourceReference String?        @map("source_reference")
  importJobId     String?        @map("import_job_id") @db.Uuid

  company       Company        @relation(fields: [companyId], references: [id])
  importJob     ImportJob?     @relation(fields: [importJobId], references: [id], onDelete: SetNull)
  loadPlanItems LoadPlanItem[]
  items         DeliveryItem[]

  @@unique([companyId, externalId])
  @@index([companyId, isArchived])
  @@index([companyId, status])
  @@index([importJobId])
  @@map("deliveries")
}

model DeliveryItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deliveryId   String   @map("delivery_id") @db.Uuid
  productName  String   @map("product_name")
  sku          String?  @map("sku")
  quantity     Decimal  @map("quantity") @db.Decimal(12, 4)
  quantityUnit String   @default("cartons") @map("quantity_unit")
  unitType     UnitType @default(STANDARD_WEIGHT) @map("unit_type")
  unitWeight   Decimal? @map("unit_weight") @db.Decimal(12, 4)
  totalWeight  Decimal  @map("total_weight") @db.Decimal(12, 4)
  notes        String?  @map("notes")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@map("delivery_items")
}

model LoadPlan {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String         @map("company_id") @db.Uuid
  truckId   String         @map("truck_id") @db.Uuid
  driverId  String?        @map("driver_id") @db.Uuid
  status    LoadPlanStatus @default(DRAFT) @map("status")
  date      DateTime       @map("date")
  notes     String?        @map("notes")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  company Company        @relation(fields: [companyId], references: [id])
  truck   Truck          @relation("TruckLoadPlans", fields: [truckId], references: [id], onDelete: Restrict)
  driver  Driver?        @relation("DriverLoadPlans", fields: [driverId], references: [id], onDelete: Restrict)
  items   LoadPlanItem[]

  @@index([companyId, date])
  @@index([companyId, status])
  @@map("load_plans")
}

model LoadPlanItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loadPlanId String   @map("load_plan_id") @db.Uuid
  deliveryId String   @map("delivery_id") @db.Uuid
  sortOrder  Int      @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  loadPlan LoadPlan @relation(fields: [loadPlanId], references: [id], onDelete: Cascade)
  delivery Delivery @relation(fields: [deliveryId], references: [id])

  @@unique([loadPlanId, deliveryId])
  @@index([loadPlanId])
  @@index([deliveryId])
  @@map("load_plan_items")
}

// ─── Data Ingestion Platform ─────────────────────────────────────────────────

model ImportJob {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String       @map("company_id") @db.Uuid
  filename    String?      @map("filename")
  sourceType  DeliverySource @default(CSV) @map("source_type")
  status      ImportStatus @default(QUEUED) @map("status")
  uploadedBy  String       @map("uploaded_by") @db.Uuid
  startedAt   DateTime?    @map("started_at")
  completedAt DateTime?    @map("completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  summary     Json?        @map("summary")

  company    Company    @relation(fields: [companyId], references: [id])
  rows       ImportRow[]
  deliveries Delivery[]

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@map("import_jobs")
}

model ImportRow {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importJobId String          @map("import_job_id") @db.Uuid
  rowNumber   Int             @map("row_number")
  rawData     Json            @map("raw_data")
  mappedData  Json?           @map("mapped_data")
  status      ImportRowStatus @default(PENDING) @map("status")
  errors      Json?           @map("errors")
  warnings    Json?           @map("warnings")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@index([status])
  @@index([importJobId, rowNumber])
  @@map("import_rows")
}
